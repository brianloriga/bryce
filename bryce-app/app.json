{
  "expo": {
    "name": "SnapStudy",
    "slug": "snap-study",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/appicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapstudy.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph textbook pages so the AI can generate practice questions.",
        "NSPhotoLibraryUsageDescription": "Used to select textbook photos from your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.snapstudy.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select textbook photos to generate practice questions."
        }
      ],
      "expo-secure-store"
    ]
  }
}
